# Supabase (use the service role key – NOT the anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the web app (default: http://localhost:3000)
BACKEND_URL=http://localhost:3000

# How often virtual devices send heartbeats, in milliseconds (default: 30000)
HEARTBEAT_INTERVAL_MS=30000

# How often pending sim_events are polled, in milliseconds (default: 5000)
POLL_INTERVAL_MS=5000
