{
  "name": "@commfire/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Commfire gateway runtime – receives LoRa mesh frames and forwards events to the backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commfire/domain": "workspace:*",
    "@commfire/protocol": "workspace:*",
    "@commfire/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
