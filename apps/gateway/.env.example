# EUI-64 of this gateway (16 hex chars, no colons)
GATEWAY_EUI=0102030405060708

# TCP port to listen for detector mesh frames
GATEWAY_LISTEN_PORT=5700

# Backend (web app) URL
BACKEND_URL=http://localhost:3000

# Heartbeat interval (ms)
HEARTBEAT_INTERVAL_MS=60000

# Stale detector threshold (ms)
STALE_THRESHOLD_MS=120000

# Firmware version reported to backend
FIRMWARE_VERSION=1.0.0
